//  UTILITY: draw one animation frame from PROGMEM
void drawFrame(const uint8_t* const* animArray, int frame) {
  const uint8_t* frameData = (const uint8_t*)pgm_read_ptr(&animArray[frame]);
  // Center the 120×160 image on the 128×160 screen (4px left margin)
  int xOff = (SCREEN_W - FRAME_W) / 2;
  tft.startWrite();
  tft.setAddrWindow(xOff, 0, FRAME_W, FRAME_H);
  for (int i = 0; i < FRAME_BYTES; i += 2) {
    uint8_t hi = pgm_read_byte(frameData + i);
    uint8_t lo = pgm_read_byte(frameData + i + 1);
    tft.pushColor((hi << 8) | lo);
  }
  tft.endWrite();
}
//  TIME HELPERS
struct tm getLocalTime() {
  struct tm ti = {};
  time_t now;
  time(&now);
  localtime_r(&now, &ti);
  return ti;
}

bool isNightTime() {
  struct tm ti = getLocalTime();
  return (ti.tm_hour >= 22 || ti.tm_hour < 6);
}

//DISPLAY: Clock face
void drawClockFace() {
  struct tm ti = getLocalTime();
  char timeBuf[9];
  char dateBuf[12];
  snprintf(timeBuf, sizeof(timeBuf), "%02d:%02d:%02d",
           ti.tm_hour, ti.tm_min, ti.tm_sec);
  snprintf(dateBuf, sizeof(dateBuf), "%04d-%02d-%02d",
           ti.tm_year + 1900, ti.tm_mon + 1, ti.tm_mday);

  // Semi-transparent bar at bottom of screen
  tft.fillRect(0, SCREEN_H - 36, SCREEN_W, 36, ST77XX_BLACK);
  tft.setTextColor(ST77XX_WHITE);
  tft.setTextSize(2);
  tft.setCursor(4, SCREEN_H - 32);
  tft.print(timeBuf);
  tft.setTextSize(1);
  tft.setCursor(10, SCREEN_H - 12);
  tft.print(dateBuf);
}

// Timer
void drawTimerScreen() {
  tft.fillScreen(ST77XX_BLACK);
  tft.setTextColor(ST77XX_CYAN);
  tft.setTextSize(2);
  tft.setCursor(10, 20);
  tft.print("TIMER");

  if (!timerRunning) {
    // Show set value
    tft.setTextSize(1);
    tft.setTextColor(ST77XX_YELLOW);
    tft.setCursor(10, 55);
    tft.print("Pot = set minutes");
    tft.setTextSize(3);
    tft.setTextColor(ST77XX_WHITE);
    tft.setCursor(30, 80);
    char buf[6];
    snprintf(buf, sizeof(buf), "%02d:00", timerMinutes);
    tft.print(buf);
    tft.setTextSize(1);
    tft.setTextColor(ST77XX_GREEN);
    tft.setCursor(10, 130);
    tft.print("Press to START");
  } else {
    // Countdown
    unsigned long elapsed = millis() - timerStartMs;
    unsigned long remaining = (elapsed < timerDurationMs) ? (timerDurationMs - elapsed) : 0;
    int remSec = remaining / 1000;
    int remMin = remSec / 60;
    remSec %= 60;
    tft.setTextSize(3);
    tft.setTextColor(ST77XX_WHITE);
    tft.setCursor(20, 80);
    char buf[6];
    snprintf(buf, sizeof(buf), "%02d:%02d", remMin, remSec);
    tft.print(buf);
    if (remaining == 0 && !timerExpired) {
      timerExpired = true;
      timerRunning = false;
      sadStartMs   = millis();
      sadActive    = true;
      dfPlayer.play(1); // play alarm track 1
    }
  }
}
// Stop watch
void drawStopwatchScreen() {
  unsigned long elapsed = swRunning ? (millis() - swStartMs + swElapsedMs) : swElapsedMs;
  unsigned long cs  = (elapsed / 10) % 100;
  unsigned long sec = (elapsed / 1000) % 60;
  unsigned long mn  = (elapsed / 60000) % 60;

  tft.fillScreen(ST77XX_BLACK);
  tft.setTextColor(ST77XX_MAGENTA);
  tft.setTextSize(2);
  tft.setCursor(4, 20);
  tft.print("STOPWATCH");

  tft.setTextSize(3);
  tft.setTextColor(ST77XX_WHITE);
  tft.setCursor(4, 70);
  char buf[9];
  snprintf(buf, sizeof(buf), "%02lu:%02lu.%02lu", mn, sec, cs);
  tft.print(buf);

  tft.setTextSize(1);
  tft.setTextColor(ST77XX_YELLOW);
  tft.setCursor(4, 120);
  tft.print("Lap alert: ");
  tft.print(swLapAlertSec);
  tft.print("s");

  tft.setTextColor(ST77XX_GREEN);
  tft.setCursor(4, 140);
  if (!swRunning) tft.print("Press = START");
  else            tft.print("Press = STOP  Hold = RESET");

  // Lap alert
  if (swRunning && swLapAlertSec > 0) {
    unsigned long elapsedSec = elapsed / 1000;
    if (elapsedSec > 0 && elapsedSec % swLapAlertSec == 0 && elapsedSec != swLastLap) {
      swLastLap = elapsedSec;
      dfPlayer.play(2); // lap alert track 2
    }
  }
}
// DISPLAY: Music screen
void drawMusicScreen() {
  tft.fillRect(0, SCREEN_H - 36, SCREEN_W, 36, ST77XX_BLACK);
  tft.setTextColor(ST77XX_GREEN);
  tft.setTextSize(1);
  tft.setCursor(4, SCREEN_H - 32);
  tft.print(musicPlaying ? "♪ PLAYING" : "■ STOPPED");
  tft.setCursor(4, SCREEN_H - 18);
  tft.print("VOL: ");
  tft.print(musicVolume);
  tft.print(" / 30");
  tft.setCursor(4, SCREEN_H - 8);
  tft.print("Press=play/stop  Hold=back");
}

//  ANIMATION TICK
void updateAnimation() {
  unsigned long now = millis();

  // Choose which animation set to use
  const uint8_t* const* animSet = nullptr;

  if (sadActive) {
    animSet = anim_sad;
    frameInterval = 150;
    if (now - sadStartMs > 30000) {
      sadActive = false;
    }
  } else if (currentMode == MODE_MUSIC) {
    animSet = anim_music;
    frameInterval = 120;
  } else if (currentMode == MODE_CLOCK) {
    animSet = isNightTime() ? anim_sleep : anim_blink;
    frameInterval = isNightTime() ? 600 : 300;
  }

  if (animSet && now - lastFrameMs > frameInterval) {
    lastFrameMs = now;
    drawFrame(animSet, animFrame);
    animFrame = (animFrame + 1) % 5;

    // Overlay clock time on animation
    if (currentMode == MODE_CLOCK) drawClockFace();
    if (currentMode == MODE_MUSIC) drawMusicScreen();
  }
}

//  POTENTIOMETER
void handlePotentiometer() {
  int raw = analogRead(POT_PIN); // 0–4095 on ESP32

  if (currentMode == MODE_CLOCK) {
    // Brightness control
    // Brightness: wire TFT BL to a spare PWM pin and uncomment:
    // int brightness = map(raw, 0, 4095, 10, 255);
    // ledcWrite(0, brightness);
  }
  else if (currentMode == MODE_TIMER && !timerRunning) {
    // Set timer minutes (1–60)
    timerMinutes = map(raw, 0, 4095, 1, 60);
  }
  else if (currentMode == MODE_STOPWATCH) {
    // Set lap alert threshold (5–120 seconds)
    swLapAlertSec = map(raw, 0, 4095, 5, 120);
  }
  else if (currentMode == MODE_MUSIC) {
    // DFMini volume (0–30)
    int newVol = map(raw, 0, 4095, 0, 30);
    if (newVol != musicVolume) {
      musicVolume = newVol;
      dfPlayer.volume(musicVolume);
    }
  }
}
//  BUTTON HANDLER
void handleButton() {
  bool pressed = (digitalRead(BTN_PIN) == LOW);
  unsigned long now = millis();

  if (pressed && !btnWasPressed) {
    // Press start
    btnPressTime = now;
    btnWasPressed = true;
  }

  if (!pressed && btnWasPressed) {
    // Released
    unsigned long holdDuration = now - btnPressTime;
    btnWasPressed = false;

    if (holdDuration >= HOLD_TIME) {
      // ── HOLD (2s): return to clock ───────────────────────
      if (currentMode == MODE_STOPWATCH) {
        // reset stopwatch first
        swRunning   = false;
        swElapsedMs = 0;
        swLastLap   = 0;
      }
      if (currentMode == MODE_MUSIC && musicPlaying) {
        dfPlayer.stop();
        musicPlaying = false;
      }
      currentMode = MODE_CLOCK;
      tft.fillScreen(ST77XX_BLACK);
      pressCount = 0;
      return;
    }

    if (holdDuration >= MUSIC_HOLD_TIME && currentMode == MODE_CLOCK) {
      // ── HOLD (0.5s) in clock: enter MUSIC mode ──────────
      currentMode = MODE_MUSIC;
      tft.fillScreen(ST77XX_BLACK);
      pressCount = 0;
      return;
    }

    // ── SHORT PRESS ──────────────────────────────────────────
    pressCount++;
    lastPressCountReset = now;
  }

  // Evaluate press count after double-press window
  if (pressCount > 0 && (millis() - lastPressCountReset > DOUBLE_PRESS_WINDOW)) {
    if (currentMode == MODE_CLOCK) {
      if (pressCount == 1) {
        // Enter TIMER mode
        currentMode  = MODE_TIMER;
        timerRunning = false;
        timerSet     = false;
        timerExpired = false;
        tft.fillScreen(ST77XX_BLACK);
      } else if (pressCount >= 2) {
        // Enter STOPWATCH mode
        currentMode = MODE_STOPWATCH;
        swRunning   = false;
        swElapsedMs = 0;
        swLastLap   = 0;
        tft.fillScreen(ST77XX_BLACK);
      }
    }
    else if (currentMode == MODE_TIMER) {
      if (!timerRunning && !timerSet) {
        // Start timer
        timerDurationMs = (unsigned long)timerMinutes * 60000UL;
        timerStartMs    = millis();
        timerRunning    = true;
        timerSet        = true;
        timerExpired    = false;
      } else if (timerRunning) {
        // Stop timer
        timerRunning = false;
      }
    }
    else if (currentMode == MODE_STOPWATCH) {
      if (!swRunning) {
        swStartMs   = millis();
        swRunning   = true;
      } else {
        swElapsedMs += millis() - swStartMs;
        swRunning    = false;
      }
    }
    else if (currentMode == MODE_MUSIC) {
      // Toggle play/stop
      if (musicPlaying) {
        dfPlayer.stop();
        musicPlaying = false;
      } else {
        dfPlayer.play(3); // music track 3
        musicPlaying = true;
      }
    }

    pressCount = 0;
  }

  if (btnWasPressed && (millis() - btnPressTime >= HOLD_TIME) && currentMode != MODE_CLOCK) {
    tft.fillRect(0, 0, SCREEN_W, 10, ST77XX_RED);
  }
}

void setup() {
  // put your setup code here, to run once:
 Serial.begin(115200);

  // TFT (BL pin wired to 3V3 for always-on, or add your own PWM pin)
  tft.initR(INITR_BLACKTAB);
  tft.setRotation(0);
  tft.fillScreen(ST77XX_BLACK);

  // Button
  pinMode(BTN_PIN, INPUT_PULLUP);

  // DFMini
  dfSerial.begin(9600, SERIAL_8N1, DF_RX, DF_TX);  // RX=GPIO20, TX=GPIO21
  if (dfPlayer.begin(dfSerial)) {
    dfPlayer.volume(15);
    Serial.println("DFMini ready");
  } else {
    Serial.println("DFMini not found — check wiring");
  }

  // WiFi + NTP
  tft.setTextColor(ST77XX_CYAN);
  tft.setTextSize(1);
  tft.setCursor(4, 60);
  tft.print("Connecting WiFi...");

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  int tries = 0;
  while (WiFi.status() != WL_CONNECTED && tries < 20) {
    delay(500);
    tries++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    configTime(GMT_OFFSET_SEC, DAYLIGHT_OFFSET_SEC, NTP_SERVER);
    tft.fillScreen(ST77XX_BLACK);
    tft.setCursor(4, 60);
    tft.setTextColor(ST77XX_GREEN);
    tft.print("Time synced!");
    delay(1000);
  } else {
    tft.fillScreen(ST77XX_BLACK);
    tft.setCursor(4, 60);
    tft.setTextColor(ST77XX_RED);
    tft.print("No WiFi — set time manually");
    // Fallback: set a default time (Jan 1 2025, 12:00:00)
    struct timeval tv = { .tv_sec = 1735728000 }; // 2025-01-01 12:00:00 UTC
    settimeofday(&tv, nullptr);
    delay(2000);
  }

  tft.fillScreen(ST77XX_BLACK);
}

void loop() {
 handleButton();
  handlePotentiometer();

  switch (currentMode) {
    case MODE_CLOCK:
      updateAnimation();
      break;

    case MODE_TIMER:
      if (millis() - lastClockRefresh > 250) {
        lastClockRefresh = millis();
        drawTimerScreen();
      }
      // If sad animation triggered by expired timer
      if (sadActive) updateAnimation();
      break;

    case MODE_STOPWATCH:
      if (millis() - lastClockRefresh > 50) {
        lastClockRefresh = millis();
        drawStopwatchScreen();
      }
      break;

    case MODE_MUSIC:
      updateAnimation();
      break;
  }
}
